# ─────────────────────────────────────────────────────────────
# BizTrack / SikaBoafo — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────
APP_ENV=local
# On Render set to: production

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/biztrack
# On Render: paste the External Database URL from your PostgreSQL service.
# Render supplies postgres:// — the app rewrites it to postgresql+psycopg:// automatically.

# ── Redis (not used yet — required for Phase 5 background jobs) ──
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────
SECRET_KEY=change-me-min-16-chars-for-dev
# On Render generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"

AUTH_TOKEN_ISSUER=biztrack-gh
AUTH_ACCESS_TOKEN_EXP_MINUTES=60
AUTH_REFRESH_TOKEN_EXP_MINUTES=10080

# Dev-only mock OTP — lets any OTP login succeed with this code.
# WARNING: REMOVE THIS IN PRODUCTION or anyone can log into any account.
AUTH_MOCK_OTP_CODE=123456

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=*
# On Render set to comma-separated allowed origins, e.g.:
#   CORS_ORIGINS=https://yourapp.com,https://api.yourapp.com

# ── Arkesel SMS ───────────────────────────────────────────────
ARKESEL_BASE_URL=https://sms.arkesel.com
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=BizTrack
ARKESEL_OTP_EXPIRY_MINUTES=5
ARKESEL_OTP_LENGTH=6
ARKESEL_OTP_TYPE=numeric
ARKESEL_OTP_MEDIUM=sms

# ── Paystack ──────────────────────────────────────────────────
PAYSTACK_API_BASE_URL=https://api.paystack.co
# Dev/local fallback keys only. Merchant-owned production accounts must use
# encrypted merchant-specific secrets stored through Settings > Payments.
PAYSTACK_SECRET_KEY_TEST=
PAYSTACK_SECRET_KEY_LIVE=
PAYSTACK_HTTP_TIMEOUT_SECONDS=15

# Merchant-owned Paystack webhooks point to our backend endpoint; the mobile app
# never receives Paystack events directly and no shared webhook secret is needed.

# Fernet key used to encrypt merchant Paystack secret keys at rest.
# On Render generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Use a DIFFERENT key from your local .env — regenerating invalidates all stored merchant keys.
PAYMENT_CONFIG_ENCRYPTION_KEY=
