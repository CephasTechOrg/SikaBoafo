# Mobile environment — pass via --dart-define-from-file=.env.json
# Convert to JSON format before use (see below).

# Backend base URL (no trailing slash)
API_BASE_URL=https://api.sikaboafo.com

# Environment tag surfaced in crash reports / analytics
ENVIRONMENT=production          # development | staging | production

# --- Usage ---
# Create mobile/.env.json:
# {
#   "API_BASE_URL": "http://10.0.2.2:8000",
#   "ENVIRONMENT": "development"
# }
# Then run: flutter run --dart-define-from-file=.env.json
